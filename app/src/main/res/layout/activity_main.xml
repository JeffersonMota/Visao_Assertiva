<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Câmera ocupa todo o fundo -->
    <androidx.camera.view.PreviewView
        android:id="@+id/viewFinder"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- OpenStreetMap Completo -->
    <org.osmdroid.views.MapView
        android:id="@+id/mapOsm"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Overlay para os desenhos -->
    <com.example.visao_pcd.OverlayView
        android:id="@+id/overlayView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Mini GPS -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/navPanel"
        android:layout_width="180dp"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:visibility="gone"
        app:cardBackgroundColor="#CC000000"
        app:cardCornerRadius="8dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:elevation="15dp">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">
            <TextView
                android:id="@+id/tvNavDestino"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Destino: Farmácia"
                android:textColor="#FFEB3B"
                android:textSize="12sp"
                android:textStyle="bold"/>
            <TextView
                android:id="@+id/tvNavDistancia"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="A 200 metros"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:layout_marginTop="4dp"/>
            <TextView
                android:id="@+id/tvNavInstrucao"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Siga em frente"
                android:textColor="#4CAF50"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginTop="4dp"/>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>


    <!-- Menu Principal -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/mainMenu"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#FF000000"
        android:elevation="20dp"
        android:visibility="visible">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="16dp"
                android:text="Visão PCD"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold" />

            <!-- Seção Básica -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="8dp"
                android:text="Modos Gratuitos"
                android:textColor="#4CAF50"
                android:textSize="11sp"
                android:textStyle="bold" />

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="3"
                android:alignmentMode="alignMargins">

                <!-- OBJETOS -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/menuBtnObjetos"
                    android:layout_width="0dp"
                    android:layout_height="90dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    app:cardBackgroundColor="#1A1A1A"
                    app:cardCornerRadius="8dp"
                    app:strokeColor="#333333"
                    app:strokeWidth="1dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="👁️" android:textSize="22sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Objetos" android:textColor="#FFFFFF" android:textSize="12sp" android:layout_marginTop="4dp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- TEXTO -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/menuBtnTexto"
                    android:layout_width="0dp"
                    android:layout_height="90dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    app:cardBackgroundColor="#1A1A1A"
                    app:cardCornerRadius="8dp"
                    app:strokeColor="#333333"
                    app:strokeWidth="1dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="📄" android:textSize="22sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Texto" android:textColor="#FFFFFF" android:textSize="12sp" android:layout_marginTop="4dp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- DINHEIRO -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/menuBtnDinheiro"
                    android:layout_width="0dp"
                    android:layout_height="90dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    app:cardBackgroundColor="#1A1A1A"
                    app:cardCornerRadius="8dp"
                    app:strokeColor="#333333"
                    app:strokeWidth="1dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="💵" android:textSize="22sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Dinheiro" android:textColor="#FFFFFF" android:textSize="12sp" android:layout_marginTop="4dp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- COR -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/menuBtnCor"
                    android:layout_width="0dp"
                    android:layout_height="90dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    app:cardBackgroundColor="#1A1A1A"
                    app:cardCornerRadius="8dp"
                    app:strokeColor="#333333"
                    app:strokeWidth="1dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🎨" android:textSize="22sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Cores" android:textColor="#FFFFFF" android:textSize="12sp" android:layout_marginTop="4dp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- MICROONDAS -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/menuBtnMicroondas"
                    android:layout_width="0dp"
                    android:layout_height="90dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    app:cardBackgroundColor="#1A1A1A"
                    app:cardCornerRadius="8dp"
                    app:strokeColor="#333333"
                    app:strokeWidth="1dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center">
                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@drawable/ic_microwave"
                            app:tint="#FFFFFF" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Microondas" android:textColor="#FFFFFF" android:textSize="12sp" android:layout_marginTop="4dp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </GridLayout>

            <!-- Seção IA -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="8dp"
                android:text="Modos Pagos"
                android:textColor="#FFD700"
                android:textSize="11sp"
                android:textStyle="bold" />

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="3"
                android:alignmentMode="alignMargins">

                <!-- AMBIENTE -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/menuBtnAmbiente"
                    android:layout_width="0dp"
                    android:layout_height="90dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    app:cardBackgroundColor="#1A1A1A"
                    app:cardCornerRadius="8dp"
                    app:strokeColor="#FFD700"
                    app:strokeWidth="1dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🌄" android:textSize="22sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Ambiente" android:textColor="#FFFFFF" android:textSize="12sp" android:layout_marginTop="4dp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- ANDANDO -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/menuBtnAndando"
                    android:layout_width="0dp"
                    android:layout_height="90dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    app:cardBackgroundColor="#1A1A1A"
                    app:cardCornerRadius="8dp"
                    app:strokeColor="#FFD700"
                    app:strokeWidth="1dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🏃" android:textSize="22sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Andando" android:textColor="#FFFFFF" android:textSize="12sp" android:layout_marginTop="4dp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- ONIBUS -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/menuBtnOnibus"
                    android:layout_width="0dp"
                    android:layout_height="90dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    app:cardBackgroundColor="#1A1A1A"
                    app:cardCornerRadius="8dp"
                    app:strokeColor="#FFD700"
                    app:strokeWidth="1dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🚌" android:textSize="22sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Ônibus" android:textColor="#FFFFFF" android:textSize="12sp" android:layout_marginTop="4dp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- PESSOA -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/menuBtnPessoa"
                    android:layout_width="0dp"
                    android:layout_height="90dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    app:cardBackgroundColor="#1A1A1A"
                    app:cardCornerRadius="8dp"
                    app:strokeColor="#FFD700"
                    app:strokeWidth="1dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="👤" android:textSize="22sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Pessoa" android:textColor="#FFFFFF" android:textSize="12sp" android:layout_marginTop="4dp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- ROUPA -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/menuBtnRoupa"
                    android:layout_width="0dp"
                    android:layout_height="90dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    app:cardBackgroundColor="#1A1A1A"
                    app:cardCornerRadius="8dp"
                    app:strokeColor="#FFD700"
                    app:strokeWidth="1dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="👕" android:textSize="22sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Roupa" android:textColor="#FFFFFF" android:textSize="12sp" android:layout_marginTop="4dp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </GridLayout>

            <!-- ZONA DE GESTO NO FUNDO -->
            <View
                android:layout_width="match_parent"
                android:layout_height="300dp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Barra de Título -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#80000000"
        app:elevation="0dp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="@string/app_name"
            app:navigationIcon="@android:drawable/ic_menu_sort_by_size"
            app:titleTextColor="@android:color/white" />
    </com.google.android.material.appbar.AppBarLayout>

    <!-- Feedback em Tempo Real -->
    <TextView
        android:id="@+id/tvLiveTextFeedback"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="20dp"
        android:background="#AA000000"
        android:gravity="center"
        android:padding="12dp"
        android:textColor="#00FFFF"
        android:textSize="18sp"
        android:textStyle="bold"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        android:elevation="15dp"/>

    <!-- Tela de Resultado -->
    <FrameLayout
        android:id="@+id/resultLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#F0000000"
        android:visibility="gone"
        android:elevation="30dp"
        android:padding="24dp">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginBottom="60dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center">

                <ImageView
                    android:id="@+id/ivCapturedImage"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:adjustViewBounds="true"
                    android:maxHeight="500dp"
                    android:scaleType="fitCenter"
                    android:layout_marginBottom="16dp"
                    android:background="#333333"
                    android:visibility="gone"/>

                <TextView
                    android:id="@+id/tvExtractedText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@android:color/white"
                    android:textSize="22sp"
                    android:text="Processando..."
                    android:lineSpacingExtra="8dp" />
            </LinearLayout>
        </ScrollView>

        <Button
            android:id="@+id/btnCloseResult"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|center_horizontal"
            android:text="Fechar" />
    </FrameLayout>

    <!-- Painel Auxiliar -->
    <LinearLayout
        android:id="@+id/buttonPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#90000000"
        android:orientation="vertical"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
